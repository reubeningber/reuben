---
import { getCollection } from 'astro:content';
const { limit } = Astro.props;
const allPosts = (await getCollection('posts')).filter(p => !p.data.draft).sort((a,b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const posts = limit ? allPosts.slice(0, limit) : allPosts;

const cloudName = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME;

// Smart image URL logic for post listings
function getListingImageConfig(imageUrl) {
  if (!imageUrl) return null;
  
  // Case 1: Already a full Cloudinary URL - use as is but optimize
  if (imageUrl.includes('res.cloudinary.com')) {
    const cloudinaryPath = imageUrl.replace(/.*\/upload\/[^/]*\//, '');
    return {
      type: 'cloudinary-full',
      blurUrl: `https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_20,e_blur:2000/v1761245976/${cloudinaryPath}`,
      mainUrl: `https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_400/v1761245976/${cloudinaryPath}`,
      srcset: `
        https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_200/v1761245976/${cloudinaryPath} 200w,
        https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_300/v1761245976/${cloudinaryPath} 300w,
        https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_400/v1761245976/${cloudinaryPath} 400w
      `
    };
  }
  
  // Case 2: Local assets/images path - fallback to standard lazy loading
  if (imageUrl.startsWith('assets/images/') || imageUrl.startsWith('/assets/images/')) {
    return {
      type: 'external',
      mainUrl: imageUrl.startsWith('/') ? imageUrl : `/${imageUrl}`
    };
  }
  
  // Case 3: Direct web_assets path (your new format)
  if (imageUrl.startsWith('web_assets/')) {
    return {
      type: 'cloudinary-web-assets',
      blurUrl: `https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_20,e_blur:2000/v1761245976/${imageUrl}`,
      mainUrl: `https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_400/v1761245976/${imageUrl}`,
      srcset: `
        https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_200/v1761245976/${imageUrl} 200w,
        https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_300/v1761245976/${imageUrl} 300w,
        https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_400/v1761245976/${imageUrl} 400w
      `
    };
  }
  
  // Case 4: Any other URL - just lazy load
  return {
    type: 'external',
    mainUrl: imageUrl
  };
}

// Function to create excerpt from post body
function createExcerpt(body, maxLength = 120) {
  // Remove markdown formatting and clean up text
  const plainText = body
    .replace(/^---[\s\S]*?---/g, '') // Remove frontmatter
    .replace(/#+\s/g, '') // Remove headings
    .replace(/\*\*(.*?)\*\*/g, '$1') // Remove bold
    .replace(/\*(.*?)\*/g, '$1') // Remove italic
    .replace(/\[(.*?)\]\(.*?\)/g, '$1') // Remove links
    .replace(/`(.*?)`/g, '$1') // Remove code
    .replace(/\n+/g, ' ') // Replace newlines with spaces
    .trim();
  
  if (plainText.length <= maxLength) {
    return plainText;
  }
  
  // Find the last complete word within the limit
  const truncated = plainText.substring(0, maxLength);
  const lastSpace = truncated.lastIndexOf(' ');
  
  return lastSpace > 0 ? truncated.substring(0, lastSpace) + '...' : truncated + '...';
}
---
<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
  {posts.map((p, index) => {
    const imageConfig = getListingImageConfig(p.data.image);
    const uniqueId = `listing-${index}`;
    
    return (
      <article class="bg-white border border-gray-200 rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow">
        {imageConfig && (
          <a href={`/articles/${p.slug}/`} class="block relative">
            {/* Cloudinary images with blur-up effect */}
            {imageConfig.type !== 'external' && (
              <>
                <!-- Blur-up placeholder -->
                <img 
                  src={imageConfig.blurUrl}
                  alt={p.data.title}
                  class="w-full h-48 object-cover absolute inset-0 transition-opacity duration-300"
                  id={`blur-${uniqueId}`}
                />
                
                <!-- Main optimized image -->
                <img 
                  src={imageConfig.mainUrl}
                  srcset={imageConfig.srcset}
                  sizes="(max-width: 768px) 100vw, 50vw"
                  alt={p.data.title}
                  class="w-full h-48 object-cover relative z-10 opacity-0 transition-opacity duration-300"
                  loading="lazy"
                  onload={`this.style.opacity='1'; document.getElementById('blur-${uniqueId}').style.opacity='0';`}
                />
              </>
            )}
            
            {/* External images - simple lazy loading */}
            {imageConfig.type === 'external' && (
              <img 
                src={imageConfig.mainUrl}
                alt={p.data.title}
                class="w-full h-48 object-cover"
                loading="lazy"
              />
            )}
          </a>
        )}
        <div class="p-6">
        <div class="flex items-center gap-2 text-sm font-semibold tracking-wide">
          <time datetime={p.data.pubDate.toISOString()} class="text-secondary whitespace-nowrap">
            {p.data.pubDate.getMonth() + 1}.{p.data.pubDate.getDate()}.{p.data.pubDate.getFullYear().toString().slice(-2)}
          </time>
          {p.data.category && (
            <>
              <span class="text-gray-300">|</span>
              <a href={`/articles/category/${p.data.category.toLowerCase().replace(/\s+/g, '-')}/`} class="text-accent hover:underline no-underline whitespace-nowrap">
                {p.data.category.toUpperCase()}
              </a>
            </>
          )}
        </div>
          <h3 class="text-xl font-bold mt-2 mb-3 text-primary tracking-wide">
            <a href={`/articles/${p.slug}/`} class="hover:text-accent no-underline">
              {p.data.title.toUpperCase()}
            </a>
          </h3>
          <p class="text-gray-700 mb-4 leading-relaxed">{createExcerpt(p.body)}</p>
          <a href={`/articles/${p.slug}/`} class="text-accent hover:underline font-semibold text-sm">
            READ MORE >
          </a>
        </div>
      </article>
    );
  })}
</div>
