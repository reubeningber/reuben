---
import { getCollection } from 'astro:content';
import { getImageConfig as getCloudinaryConfig } from '../utils/cloudinary';
import { isPublished } from '../utils/publish';
import { createExcerpt, slugifyCategory } from '../utils/content';

const { limit } = Astro.props;

const allPosts = (await getCollection('posts'))
  .filter(p => isPublished(p.data.pubDate, p.data.draft))
  .sort((a,b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const posts = limit ? allPosts.slice(0, limit) : allPosts;

const cloudName = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME;

function getListingImageConfig(imageUrl) {
  return getCloudinaryConfig(imageUrl, cloudName, [200, 300, 400]);
}
---
<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
<div class="space-y-8 md:space-y-12">
  <!-- Recent Posts Cards -->
  <section>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
      {posts.slice(0, 4).map((p, index) => {
        const imageConfig = getListingImageConfig(p.data.image);
        const uniqueId = `listing-${index}`;
        
        return (
          <article class="bg-white border border-gray-200 rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow">
            {imageConfig && (
              <a href={`/articles/${p.slug}/`} class="block relative">
                {/* Cloudinary images with blur-up effect */}
                {imageConfig.type === 'cloudinary' && (
                  <>
                    <!-- Blur-up placeholder -->
                    <img 
                      src={imageConfig.blurUrl}
                      alt={p.data.title}
                      class="w-full h-40 md:h-48 object-cover absolute inset-0 transition-opacity duration-300"
                      id={`blur-${uniqueId}`}
                    />
                    
                    <!-- Main optimized image -->
                    <img 
                      src={imageConfig.mainUrl}
                      srcset={imageConfig.srcset}
                      sizes="(max-width: 768px) 100vw, 50vw"
                      alt={p.data.title}
                      class="w-full h-40 md:h-48 object-cover relative z-10 opacity-0 transition-opacity duration-300"
                      loading="lazy"
                      onload={`this.style.opacity='1'; document.getElementById('blur-${uniqueId}').style.opacity='0';`}
                    />
                  </>
                )}
                
                {/* External images - simple lazy loading */}
                {imageConfig.type === 'external' && (
                  <img 
                    src={imageConfig.mainUrl}
                    alt={p.data.title}
                    class="w-full h-40 md:h-48 object-cover"
                    loading="lazy"
                  />
                )}
              </a>
            )}
            <div class="p-4 md:p-6">
            <div class="flex items-center gap-2 text-xs md:text-sm font-semibold tracking-wide mb-3">
              <time datetime={p.data.pubDate.toISOString()} class="text-secondary whitespace-nowrap">
                {(() => {
                  // Parse date as intended (YYYY-MM-DD) without timezone conversion
                  const dateStr = p.data.pubDate instanceof Date 
                    ? p.data.pubDate.toISOString().split('T')[0]
                    : typeof p.data.pubDate === 'string' ? p.data.pubDate : new Date(p.data.pubDate).toISOString().split('T')[0];
                  const [year, month, day] = dateStr.split('-');
                  return `${month}.${day}.${year.slice(-2)}`;
                })()} 
              </time>
              {p.data.category && (
                <>
                  <span class="text-gray-300">•</span>
                  <a href={`/articles/category/${slugifyCategory(p.data.category)}/`} class="text-accent hover:underline no-underline whitespace-nowrap">
                    {p.data.category.toUpperCase()}
                  </a>
                </>
              )}
            </div>
              <h3 class="text-lg md:text-xl font-bold mb-2 md:mb-3 text-primary tracking-wide leading-tight">
                <a href={`/articles/${p.slug}/`} class="hover:text-accent no-underline">
                  {p.data.title.toUpperCase()}
                </a>
              </h3>
              <p class="text-gray-700 mb-3 md:mb-4 leading-relaxed text-sm md:text-base line-clamp-2">{p.data.subTitle || createExcerpt(p.body)}</p>
              <a href={`/articles/${p.slug}/`} class="inline-flex items-center gap-1 text-accent hover:underline font-semibold text-xs md:text-sm">
                READ MORE
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M13.172 12l-4.95-4.95 1.414-1.414L16 12l-6.364 6.364-1.414-1.414z"/></svg>
              </a>
            </div>
          </article>
        );
      })}
    </div>
  </section>

  <!-- All Articles List -->
  {posts.length > 4 && (
    <section>
      <div class="space-y-4 md:space-y-3">
        {posts.slice(4).map((p) => (
          <article class="py-4 md:py-3 border-b border-gray-100 last:border-b-0 hover:bg-gray-50 transition-colors rounded px-2">
            
            {/* Mobile: Stacked Layout */}
            <div class="block md:hidden">
              <div class="flex items-center gap-2 text-xs font-semibold tracking-wide text-secondary mb-2">
                <time datetime={p.data.pubDate.toISOString()}>
                  {(() => {
                    const dateStr = p.data.pubDate instanceof Date 
                      ? p.data.pubDate.toISOString().split('T')[0]
                      : typeof p.data.pubDate === 'string' ? p.data.pubDate : new Date(p.data.pubDate).toISOString().split('T')[0];
                    const [year, month, day] = dateStr.split('-');
                    return `${month}.${day}.${year.slice(-2)}`;
                  })()}
                </time>
                {p.data.category && (
                  <>
                    <span class="text-gray-300">•</span>
                    <a href={`/articles/category/${slugifyCategory(p.data.category)}/`} class="text-accent hover:underline no-underline">
                      {p.data.category.toUpperCase()}
                    </a>
                  </>
                )}
              </div>
              
              <h3 class="text-lg font-semibold text-primary tracking-wide leading-tight mb-2">
                <a href={`/articles/${p.slug}/`} class="hover:text-accent no-underline">
                  {p.data.title}
                </a>
              </h3>
              
              {p.data.subTitle && (
                <p class="text-gray-600 text-sm leading-relaxed">{p.data.subTitle}</p>
              )}
            </div>

            {/* Desktop: Column Layout */}
            <div class="hidden md:flex items-start gap-4">
              <time datetime={p.data.pubDate.toISOString()} class="text-sm text-secondary font-medium whitespace-nowrap mt-1 w-20 flex-shrink-0">
                {(() => {
                  const dateStr = p.data.pubDate instanceof Date 
                    ? p.data.pubDate.toISOString().split('T')[0]
                    : typeof p.data.pubDate === 'string' ? p.data.pubDate : new Date(p.data.pubDate).toISOString().split('T')[0];
                  const [year, month, day] = dateStr.split('-');
                  return `${month}.${day}.${year.slice(-2)}`;
                })()}
              </time>
              
              <div class="flex-1 min-w-0">
                <h3 class="text-lg font-semibold text-primary tracking-wide leading-tight">
                  <a href={`/articles/${p.slug}/`} class="hover:text-accent no-underline">
                    {p.data.title}
                  </a>
                </h3>
                {p.data.subTitle && (
                  <p class="text-gray-600 text-sm mt-1 leading-relaxed">{p.data.subTitle}</p>
                )}
              </div>
              
              {p.data.category && (
                <a href={`/articles/category/${slugifyCategory(p.data.category)}/`} class="text-xs font-semibold text-accent bg-accent bg-opacity-10 px-2 py-1 rounded whitespace-nowrap flex-shrink-0 hover:bg-opacity-20 transition-colors no-underline">
                  {p.data.category.toUpperCase()}
                </a>
              )}
            </div>
          </article>
        ))}
      </div>
    </section>
  )}
</div>
