---
const { isHomepage = false } = Astro.props;

const nav = [
  { href: '/start-here/', label: 'START HERE' },
  { href: '/articles/', label: 'ARTICLES' },
  { href: '/field-notes/', label: 'FIELD NOTES' },
  { href: 'https://photos.reubeningber.com', label: 'PHOTOS', external: true },
  { href: '/contact/', label: 'CONTACT' },
];

const pathname = Astro.url.pathname;
function isActive(href: string, external?: boolean) {
  if (external) return false;
  return pathname === href || pathname.startsWith(href);
}
---

<header class="bg-white border-b border-gray-200 relative z-40">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 sm:h-24 items-center justify-between">

      <!-- Logo / Branding -->
      <a href="/" class="flex items-center">
        {isHomepage ? (
          <span class="font-rock-salt text-xl sm:text-2xl lg:text-3xl text-black">Reuben Ingber</span>
        ) : (
          <div class="flex items-center space-x-3 sm:space-x-4">
            <img
              src="https://res.cloudinary.com/dt3vcpkj6/image/upload/f_auto,w_150,h_150,c_thumb,g_face,z_0.8/v1761252984/web_assets/Reuben_Ingber_Square.jpg"
              alt="Reuben Ingber"
              class="w-10 h-10 sm:w-16 sm:h-16 lg:w-20 lg:h-20 rounded-full object-cover"
              loading="lazy"
            />
            <span class="font-rock-salt text-lg sm:text-xl lg:text-3xl text-black">Reuben Ingber</span>
          </div>
        )}
      </a>

      <!-- Desktop nav -->
      <nav class="hidden sm:flex items-center space-x-3 sm:space-x-6 lg:space-x-8">
        {nav.map((item) => (
          <a
            href={item.href}
            target={item.external ? '_blank' : undefined}
            rel={item.external ? 'noopener noreferrer' : undefined}
            class={`px-1 sm:px-3 py-2 text-xs sm:text-sm font-medium transition-colors whitespace-nowrap ${isActive(item.href, item.external) ? 'text-orange-600' : 'text-gray-900 hover:text-orange-600'}`}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <!-- Hamburger button (mobile only) -->
      <button
        id="menu-toggle"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="mobile-drawer"
        class="sm:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5 rounded focus:outline-none focus-visible:ring-2 focus-visible:ring-orange-500"
      >
        <span class="block w-6 h-0.5 bg-gray-800"></span>
        <span class="block w-6 h-0.5 bg-gray-800"></span>
        <span class="block w-6 h-0.5 bg-gray-800"></span>
      </button>

    </div>
  </div>
</header>

<!-- Mobile drawer — full screen -->
<nav
  id="mobile-drawer"
  role="dialog"
  aria-modal="true"
  aria-label="Navigation menu"
  class="fixed inset-0 bg-white z-50 -translate-x-full transition-transform duration-300 ease-in-out sm:hidden flex flex-col"
>
  <!-- Drawer header -->
  <div class="flex items-center justify-between px-6 py-5 border-b border-gray-100">
    <a href="/" class="flex items-center gap-3">
      <img
        src="https://res.cloudinary.com/dt3vcpkj6/image/upload/f_auto,w_150,h_150,c_thumb,g_face,z_0.8/v1761252984/web_assets/Reuben_Ingber_Square.jpg"
        alt="Reuben Ingber"
        class="w-10 h-10 rounded-full object-cover"
      />
      <span class="font-rock-salt text-lg text-black">Reuben Ingber</span>
    </a>
    <button
      id="menu-close"
      aria-label="Close navigation menu"
      class="flex items-center justify-center w-10 h-10 text-gray-500 hover:text-gray-900 focus:outline-none focus-visible:ring-2 focus-visible:ring-orange-500"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Nav links -->
  <ul class="flex flex-col px-4 py-6 gap-1">
    {nav.map((item) => (
      <li>
        <a
          href={item.href}
          target={item.external ? '_blank' : undefined}
          rel={item.external ? 'noopener noreferrer' : undefined}
          class={`flex items-center justify-between px-3 py-4 text-base font-semibold tracking-wide rounded-md transition-colors ${isActive(item.href, item.external) ? 'text-orange-600 bg-orange-50' : 'text-gray-800 hover:text-orange-600 hover:bg-orange-50'}`}
        >
          {item.label}
          {item.external && (
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          )}
        </a>
      </li>
    ))}
  </ul>

  <!-- About + Connect -->
  <div class="mt-auto px-6 py-8 border-t border-gray-100 space-y-6">
    <div>
      <p class="text-xs font-bold tracking-widest text-gray-400 uppercase mb-2">Reuben Ingber</p>
      <p class="text-sm text-gray-500 leading-relaxed">
        Father of two in Queens, NY, runner, and photo-taker. Engineering Manager at Business Insider.
      </p>
    </div>
    <div>
      <p class="text-xs font-bold tracking-widest text-gray-400 uppercase mb-3">Let's Connect</p>
      <ul class="flex gap-5">
        <li>
          <a href="https://instagram.com/reubeningber" target="_blank" rel="noopener noreferrer" class="text-orange-500 hover:text-gray-900 transition-colors" aria-label="Instagram">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" />
            </svg>
          </a>
        </li>
        <li>
          <a href="https://linkedin.com/in/reubeningber" target="_blank" rel="noopener noreferrer" class="text-orange-500 hover:text-gray-900 transition-colors" aria-label="LinkedIn">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </li>
        <li>
          <a href="https://github.com/reubeningber" target="_blank" rel="noopener noreferrer" class="text-orange-500 hover:text-gray-900 transition-colors" aria-label="GitHub">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
            </svg>
          </a>
        </li>
        <li>
          <a href="/rss.xml" class="text-orange-500 hover:text-gray-900 transition-colors" aria-label="RSS Feed">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20 4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
            </svg>
          </a>
        </li>
      </ul>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('menu-toggle');
  const close = document.getElementById('menu-close');
  const drawer = document.getElementById('mobile-drawer');

  function openMenu() {
    drawer.classList.remove('-translate-x-full');
    toggle.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    drawer.classList.add('-translate-x-full');
    toggle.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    toggle.focus();
  }

  toggle.addEventListener('click', openMenu);
  close.addEventListener('click', closeMenu);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });
</script>
