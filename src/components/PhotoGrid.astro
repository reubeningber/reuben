---
const { items, buildUrl } = Astro.props;
---
<div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
  {items.map((it) => (
    <a href={buildUrl(it.publicId, 1600)} target="_blank" rel="noopener" class="block">
      <img src={buildUrl(it.publicId, 600)} alt={it.caption || ''} loading="lazy" class="w-full h-auto rounded-lg" />
    </a>
  ))}
</div>
