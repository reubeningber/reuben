---
import Base from "./BaseLayout.astro";
import { getCollection } from 'astro:content';

const { frontmatter, currentPost } = Astro.props;

const cloudName = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME;

// Smart image URL logic
function getImageConfig(imageUrl) {
  if (!imageUrl) return null;
  
  // Case 1: Already a full Cloudinary URL - use as is but optimize
  if (imageUrl.includes('res.cloudinary.com')) {
    const cloudinaryPath = imageUrl.replace(/.*\/upload\/[^/]*\//, '');
    return {
      type: 'cloudinary-full',
      blurUrl: `https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_20,e_blur:2000/v1761245976/${cloudinaryPath}`,
      mainUrl: `https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_800/v1761245976/${cloudinaryPath}`,
      srcset: `
        https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_400/v1761245976/${cloudinaryPath} 400w,
        https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_600/v1761245976/${cloudinaryPath} 600w,
        https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_800/v1761245976/${cloudinaryPath} 800w
      `
    };
  }
  
  // Case 2: Local assets/images path - convert to Cloudinary web_assets
  if (imageUrl.startsWith('assets/images/') || imageUrl.startsWith('/assets/images/')) {
    const fileName = imageUrl.replace(/^\/?(assets\/images\/)/, '');
    return {
      type: 'cloudinary-converted',
      blurUrl: `https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_20,e_blur:2000/v1761245976/web_assets/${fileName}`,
      mainUrl: `https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_800/v1761245976/web_assets/${fileName}`,
      srcset: `
        https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_400/v1761245976/web_assets/${fileName} 400w,
        https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_600/v1761245976/web_assets/${fileName} 600w,
        https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_800/v1761245976/web_assets/${fileName} 800w
      `
    };
  }
  
  // Case 3: Direct web_assets path (your new format)
  if (imageUrl.startsWith('web_assets/')) {
    return {
      type: 'cloudinary-web-assets',
      blurUrl: `https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_20,e_blur:2000/v1761245976/${imageUrl}`,
      mainUrl: `https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_800/v1761245976/${imageUrl}`,
      srcset: `
        https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_400/v1761245976/${imageUrl} 400w,
        https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_600/v1761245976/${imageUrl} 600w,
        https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_800/v1761245976/${imageUrl} 800w
      `
    };
  }
  
  // Case 4: Any other URL - just lazy load
  return {
    type: 'external',
    mainUrl: imageUrl
  };
}

const imageConfig = getImageConfig(frontmatter?.image);

// Get navigation posts
const allPosts = await getCollection("posts");
const sortedPosts = allPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

const currentPostIndex = sortedPosts.findIndex(post => post.slug === currentPost?.slug);
const previousPost = currentPostIndex > 0 ? sortedPosts[currentPostIndex - 1] : undefined;
const nextPost = currentPostIndex < sortedPosts.length - 1 ? sortedPosts[currentPostIndex + 1] : undefined;
---
<Base title={`${frontmatter?.title || 'Blog Post'} · Reuben Ingber`} description="Blog post by Reuben Ingber">
  <article class="max-w-3xl">
    {imageConfig && (
      <div class="mb-8 relative">
        {/* Cloudinary images with blur-up effect */}
        {(imageConfig.type !== 'external') && (
          <>
            <!-- Blur-up placeholder -->
            <img 
              src={imageConfig.blurUrl}
              alt={frontmatter.title || 'Blog post image'}
              class="w-full h-64 md:h-80 object-cover rounded-lg shadow-sm absolute inset-0 z-0 opacity-100 transition-opacity duration-300"
              id={`blur-placeholder-${Math.random().toString(36).substr(2, 9)}`}
            />
            
            <!-- Main optimized image -->
            <img 
              src={imageConfig.mainUrl}
              srcset={imageConfig.srcset}
              sizes="(max-width: 768px) 100vw, 800px"
              alt={frontmatter.title || 'Blog post image'}
              class="w-full h-64 md:h-80 object-cover rounded-lg shadow-sm relative z-10 opacity-0 transition-opacity duration-300"
              loading="lazy"
              onload={`this.style.opacity='1'; this.previousElementSibling.style.opacity='0';`}
            />
          </>
        )}
        
        {/* External images - simple lazy loading */}
        {imageConfig.type === 'external' && (
          <img 
            src={imageConfig.mainUrl}
            alt={frontmatter.title || 'Blog post image'}
            class="w-full h-64 md:h-80 object-cover rounded-lg shadow-sm"
            loading="lazy"
          />
        )}
        
        {frontmatter?.imageCredit && (
          <p class="text-xs text-gray-400 mt-2 text-right">
            {frontmatter?.imageCreditUrl ? (
              <a href={frontmatter.imageCreditUrl} target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors">
                {frontmatter.imageCredit}
              </a>
            ) : (
              <span>{frontmatter.imageCredit}</span>
            )}
          </p>
        )}
      </div>
    )}
    
    <header class="mb-8 pb-6 border-b border-gray-200">
      <div class="flex items-center gap-2 text-sm font-semibold tracking-wide">
        <time datetime={frontmatter?.pubDate?.toISOString?.() || frontmatter?.pubDate} class="text-secondary">
          {frontmatter?.pubDate?.toLocaleDateString?.('en-US', { 
            year: 'numeric', 
            month: 'short', 
            day: 'numeric' 
          }).toUpperCase() || frontmatter?.pubDate}
        </time>
        {frontmatter?.category && (
          <>
            <span class="text-gray-300">|</span>
            <a href={`/articles/category/${frontmatter.category.toLowerCase().replace(/\s+/g, '-')}/`} class="text-accent hover:underline no-underline">
              {frontmatter.category.toUpperCase()}
            </a>
          </>
        )}
      </div>
      <h1 class="text-3xl font-bold mt-2 text-primary tracking-wide">{(frontmatter?.title || 'Blog Post').toUpperCase()}</h1>
    </header>
    
    <div class="prose prose-lg prose-neutral max-w-none prose-headings:text-primary prose-headings:font-bold prose-headings:tracking-wide prose-h2:text-3xl prose-h2:mt-12 prose-h2:mb-6 prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-4 prose-p:text-gray-800 prose-p:leading-relaxed prose-p:mb-6 prose-strong:text-primary prose-strong:font-semibold prose-a:text-accent prose-a:no-underline hover:prose-a:underline prose-hr:border-gray-200 prose-hr:my-12 prose-ul:my-6 prose-ul:pl-6 prose-ol:my-6 prose-ol:pl-6 prose-li:text-gray-800 prose-li:leading-relaxed prose-li:mb-2 prose-li:marker:text-accent">
      <slot />
    </div>

    <!-- Post Navigation -->
    {(previousPost || nextPost) && (
      <nav class="border-t border-gray-200 mt-12 pt-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <!-- Previous Post -->
          <div class="text-left">
            {previousPost && (
              <div>
                <p class="text-sm text-secondary font-semibold tracking-wide mb-2">PREVIOUS POST</p>
                <a href={`/articles/${previousPost.slug}/`} class="block group">
                  <h3 class="text-lg font-bold text-primary group-hover:text-accent transition-colors tracking-wide">
                    {previousPost.data.title.toUpperCase()}
                  </h3>
                  <p class="text-sm text-secondary mt-1">
                    {previousPost.data.pubDate.toLocaleDateString('en-US', { 
                      year: 'numeric', 
                      month: 'short', 
                      day: 'numeric' 
                    })}
                  </p>
                </a>
              </div>
            )}
          </div>
          
          <!-- Next Post -->
          <div class="text-left md:text-right">
            {nextPost && (
              <div>
                <p class="text-sm text-secondary font-semibold tracking-wide mb-2">NEXT POST</p>
                <a href={`/articles/${nextPost.slug}/`} class="block group">
                  <h3 class="text-lg font-bold text-primary group-hover:text-accent transition-colors tracking-wide">
                    {nextPost.data.title.toUpperCase()}
                  </h3>
                  <p class="text-sm text-secondary mt-1">
                    {nextPost.data.pubDate.toLocaleDateString('en-US', { 
                      year: 'numeric', 
                      month: 'short', 
                      day: 'numeric' 
                    })}
                  </p>
                </a>
              </div>
            )}
          </div>
        </div>
      </nav>
    )}
  </article>
</Base>
