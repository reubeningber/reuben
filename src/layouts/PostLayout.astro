---
import Base from "./BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { getCollection } from 'astro:content';

const { frontmatter, currentPost } = Astro.props;

const cloudName = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME;

// Smart image URL logic
/**
 * @param {string | null | undefined} imageUrl
 */
function getImageConfig(imageUrl: string | null | undefined) {
  if (!imageUrl) return null;
  
  // Case 1: Already a full Cloudinary URL - use as is but optimize
  if (imageUrl.includes('res.cloudinary.com')) {
    const cloudinaryPath = imageUrl.replace(/.*\/upload\/[^/]*\//, '');
    return {
      type: 'cloudinary-full',
      blurUrl: `https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_20,e_blur:2000/v1761245976/${cloudinaryPath}`,
      mainUrl: `https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_800/v1761245976/${cloudinaryPath}`,
      srcset: `
        https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_400/v1761245976/${cloudinaryPath} 400w,
        https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_600/v1761245976/${cloudinaryPath} 600w,
        https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_800/v1761245976/${cloudinaryPath} 800w
      `
    };
  }
  
  // Case 2: Local assets/images path - fallback to standard lazy loading
  if (imageUrl.startsWith('assets/images/') || imageUrl.startsWith('/assets/images/')) {
    return {
      type: 'external',
      mainUrl: imageUrl.startsWith('/') ? imageUrl : `/${imageUrl}`
    };
  }
  
  // Case 3: Direct web_assets path (your new format)
  if (imageUrl.startsWith('web_assets/')) {
    return {
      type: 'cloudinary-web-assets',
      blurUrl: `https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_20,e_blur:2000/v1761245976/${imageUrl}`,
      mainUrl: `https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_800/v1761245976/${imageUrl}`,
      srcset: `
        https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_400/v1761245976/${imageUrl} 400w,
        https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_600/v1761245976/${imageUrl} 600w,
        https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_800/v1761245976/${imageUrl} 800w
      `
    };
  }
  
  // Case 4: Any other URL - just lazy load
  return {
    type: 'external',
    mainUrl: imageUrl
  };
}

const imageConfig = getImageConfig(frontmatter?.image);

// Generate og:image for social sharing
/**
 * @param {string | null | undefined} imageUrl
 */
function getOgImage(imageUrl: string | null | undefined) {
  if (!imageUrl) {
    return "https://res.cloudinary.com/dt3vcpkj6/image/upload/f_auto,w_1200,h_630,c_fill,g_face/v1761245976/web_assets/reuben_ingber_october_2025.jpg";
  }
  
  // Case 1: Already a full Cloudinary URL
  if (imageUrl.includes('res.cloudinary.com')) {
    const cloudinaryPath = imageUrl.replace(/.*\/upload\/[^/]*\//, '');
    return `https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_1200,h_630,c_fill/v1761245976/${cloudinaryPath}`;
  }
  
  // Case 2: Direct web_assets path
  if (imageUrl.startsWith('web_assets/')) {
    return `https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_1200,h_630,c_fill/v1761245976/${imageUrl}`;
  }
  
  // Case 3: Any other URL - fallback to default
  return "https://res.cloudinary.com/dt3vcpkj6/image/upload/f_auto,w_1200,h_630,c_fill,g_face/v1761245976/web_assets/reuben_ingber_october_2025.jpg";
}

const ogImage = getOgImage(frontmatter?.image);

/**
 * @param {string | Date | null | undefined} dateValue
 */
function formatDateOnly(dateValue: string | Date | null | undefined) {
  if (!dateValue) return '';

  const date = dateValue instanceof Date ? dateValue : new Date(dateValue);
  return new Intl.DateTimeFormat('en-US', {
    timeZone: 'UTC',
    year: 'numeric',
    month: 'short',
    day: 'numeric'
  }).format(date).toUpperCase();
}

/**
 * @param {string | Date | null | undefined} dateValue
 */
function getDateOnlyIso(dateValue: string | Date | null | undefined) {
  if (!dateValue) return '';

  const date = dateValue instanceof Date ? dateValue : new Date(dateValue);
  return date.toISOString().split('T')[0];
}

// Generate meta description from frontmatter or content excerpt
function generateDescription() {
  if (frontmatter?.description) {
    return frontmatter.description;
  }
  
  // Extract first paragraph as fallback
  const content = currentPost?.body || '';
  const firstParagraph = content.split('\n\n')[0]?.replace(/[#*\[\]]/g, '').trim();
  return firstParagraph?.substring(0, 160) || 'A blog post by Reuben Ingber';
}

const metaDescription = generateDescription();

// Create blog posting schema with enhanced keywords
const blogPostingSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "@id": `https://reubeningber.com/articles/${currentPost?.slug}/#article`,
  "headline": frontmatter?.title,
  "description": metaDescription,
  "image": {
    "@type": "ImageObject",
    "url": imageConfig?.mainUrl || "https://res.cloudinary.com/dt3vcpkj6/image/upload/f_auto,w_1200,h_630,c_fill,g_face/v1761245976/web_assets/reuben_ingber_october_2025.jpg",
    "width": 800,
    "height": 533
  },
  "datePublished": frontmatter?.pubDate?.toISOString?.() || frontmatter?.pubDate,
  "dateModified": frontmatter?.updatedDate?.toISOString?.() || frontmatter?.pubDate?.toISOString?.() || frontmatter?.pubDate,
  "author": { "@id": "https://reubeningber.com/#person" },
  "publisher": { "@id": "https://reubeningber.com/#person" },
  "mainEntityOfPage": `https://reubeningber.com/articles/${currentPost?.slug}/`,
  "articleSection": frontmatter?.category || "General",
  "keywords": frontmatter?.tags?.join(', ') || frontmatter?.category || 'blog',
  "inLanguage": "en-US"
};

// Get navigation posts
/** @type {import('astro:content').CollectionEntry<'posts'>[]} */
const allPosts = await getCollection("posts");
const sortedPosts = allPosts
  .filter((post: import('astro:content').CollectionEntry<'posts'>) => !post.data.draft)
  .sort((a: import('astro:content').CollectionEntry<'posts'>, b: import('astro:content').CollectionEntry<'posts'>) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

const currentPostIndex = sortedPosts.findIndex((post: import('astro:content').CollectionEntry<'posts'>) => post.slug === currentPost?.slug);
const previousPost = currentPostIndex > 0 ? sortedPosts[currentPostIndex - 1] : undefined;
const nextPost = currentPostIndex < sortedPosts.length - 1 ? sortedPosts[currentPostIndex + 1] : undefined;

// Get related posts in same category (Fix 8)
const relatedPosts = frontmatter?.category
  ? sortedPosts
      .filter((post: import('astro:content').CollectionEntry<'posts'>) =>
        post.slug !== currentPost?.slug &&
        post.data.category?.toLowerCase() === frontmatter.category.toLowerCase()
      )
      .slice(0, 3)
  : [];
---
<Base title={`${frontmatter?.title || 'Blog Post'} · Reuben Ingber`} description={metaDescription} ogImage={ogImage} keywords={frontmatter?.tags?.join(', ')}>
  <!-- Blog Post Structured Data -->
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(blogPostingSchema)}></script>
  {frontmatter?.canonicalURL && (
    <link rel="canonical" href={frontmatter.canonicalURL} slot="head" />
  )}
  <Breadcrumbs items={[
    { name: "Home", item: "https://reubeningber.com/" },
    { name: "Articles", item: "https://reubeningber.com/articles/" },
    { name: frontmatter?.title || "Article", item: `https://reubeningber.com/articles/${currentPost?.slug}/` }
  ]} />
  <article class="max-w-3xl">
    {imageConfig && (
      <div class="mb-4 relative group">
        {/* Cloudinary images with blur-up effect */}
        {(imageConfig.type !== 'external') && (
          <>
            <!-- Blur-up placeholder -->
            <img 
              src={imageConfig.blurUrl}
              alt={frontmatter.imageAlt || frontmatter.title || 'Blog post image'}
              class="w-full h-64 md:h-80 object-cover rounded-lg shadow-sm absolute inset-0 z-0 opacity-100 transition-opacity duration-300"
              id={`blur-placeholder-${Math.random().toString(36).substr(2, 9)}`}
              title={frontmatter?.imageCredit || ''}
            />
            
            <!-- Main optimized image -->
            <img 
              src={imageConfig.mainUrl}
              srcset={imageConfig.srcset}
              sizes="(max-width: 768px) 100vw, 800px"
              alt={frontmatter.imageAlt || frontmatter.title || 'Blog post image'}
              class="w-full h-64 md:h-80 object-cover rounded-lg shadow-sm relative z-10 opacity-0 transition-opacity duration-300"
              loading="lazy"
              title={frontmatter?.imageCredit || ''}
              onload={`this.style.opacity='1'; this.previousElementSibling.style.opacity='0';`}
            />
          </>
        )}
        
        {/* External images - simple lazy loading */}
        {imageConfig.type === 'external' && (
          <img 
            src={imageConfig.mainUrl}
            alt={frontmatter.imageAlt || frontmatter.title || 'Blog post image'}
            class="w-full h-64 md:h-80 object-cover rounded-lg shadow-sm"
            loading="lazy"
            title={frontmatter?.imageCredit || ''}
          />
        )}
        
        {/* Image credit overlay - appears on hover */}
        {frontmatter?.imageCredit && (
          <div class="absolute bottom-2 right-2 opacity-0 group-hover:opacity-100 transition-opacity duration-200 bg-black bg-opacity-70 text-white text-xs px-2 py-1 rounded">
            {frontmatter?.imageCreditUrl ? (
              <a href={frontmatter.imageCreditUrl} target="_blank" rel="noopener noreferrer" class="text-white hover:text-gray-300 no-underline">
                Photo: {frontmatter.imageCredit}
              </a>
            ) : (
              <span>Photo: {frontmatter.imageCredit}</span>
            )}
          </div>
        )}
      </div>
    )}
    
    <header class="mb-6 pb-4 border-b border-gray-200">
      <div class="flex items-center gap-2 text-sm font-semibold tracking-wide">
        <time datetime={getDateOnlyIso(frontmatter?.pubDate)} class="text-secondary">
          {formatDateOnly(frontmatter?.pubDate) || frontmatter?.pubDate}
        </time>
        {frontmatter?.category && (
          <>
            <span class="text-gray-300">|</span>
            <a href={`/articles/category/${frontmatter.category.toLowerCase().replace(/\s+/g, '-')}/`} class="text-accent hover:underline no-underline">
              {frontmatter.category.toUpperCase()}
            </a>
          </>
        )}
      </div>
      <h1 class="text-3xl font-bold mt-2 text-primary tracking-wide">{(frontmatter?.title || 'Blog Post').toUpperCase()}</h1>
      {frontmatter?.subTitle && (
        <p class="text-lg text-orange-600 mt-3 font-medium leading-relaxed">{frontmatter.subTitle}</p>
      )}
      <div role="doc-byline" class="mt-3 text-sm text-secondary flex flex-wrap items-center gap-x-2 gap-y-1">
        <span>By <strong class="text-primary">Reuben Ingber</strong></span>
        <span class="text-gray-300">·</span>
        <time datetime={getDateOnlyIso(frontmatter?.pubDate)}>
          {frontmatter?.pubDate ? new Intl.DateTimeFormat('en-US', { timeZone: 'UTC', month: 'long', day: 'numeric', year: 'numeric' }).format(frontmatter.pubDate instanceof Date ? frontmatter.pubDate : new Date(frontmatter.pubDate)) : ''}
        </time>
        {frontmatter?.category && (
          <>
            <span class="text-gray-300">·</span>
            <a href={`/articles/category/${frontmatter.category.toLowerCase().replace(/\s+/g, '-')}/`} class="text-accent hover:underline no-underline">
              {frontmatter.category}
            </a>
          </>
        )}
      </div>
    </header>
    
    <div class="prose prose-lg prose-neutral max-w-none prose-headings:text-primary prose-headings:font-bold prose-headings:tracking-wide prose-h2:text-3xl prose-h2:mt-12 prose-h2:mb-6 prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-4 prose-p:text-gray-800 prose-p:leading-relaxed prose-p:mb-6 prose-strong:text-primary prose-strong:font-semibold prose-a:text-accent prose-a:no-underline hover:prose-a:underline prose-hr:border-gray-200 prose-hr:my-12 prose-ul:my-6 prose-ul:pl-6 prose-ol:my-6 prose-ol:pl-6 prose-li:text-gray-800 prose-li:leading-relaxed prose-li:mb-2 prose-li:marker:text-accent">
      <slot />
    </div>

    <!-- Related Posts -->
    {relatedPosts.length > 0 && (
      <aside class="border-t border-gray-200 mt-12 pt-6">
        <h2 class="text-lg font-bold text-primary tracking-wide mb-4">MORE IN {frontmatter.category.toUpperCase()}</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          {relatedPosts.map((post: import('astro:content').CollectionEntry<'posts'>) => (
            <article class="bg-white border border-gray-200 rounded-lg p-4 hover:shadow-sm transition-shadow">
              <time class="text-xs text-secondary font-medium block mb-1">
                {(() => {
                  const dateStr = post.data.pubDate instanceof Date
                    ? post.data.pubDate.toISOString().split('T')[0]
                    : String(post.data.pubDate);
                  const [year, month, day] = dateStr.split('-');
                  const d = new Date(parseInt(year), parseInt(month) - 1, parseInt(day));
                  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
                })()}
              </time>
              <h3 class="text-sm font-semibold text-primary leading-snug">
                <a href={`/articles/${post.slug}/`} class="hover:text-accent no-underline">
                  {post.data.title}
                </a>
              </h3>
            </article>
          ))}
        </div>
      </aside>
    )}

    <!-- Post Navigation -->
    {(previousPost || nextPost) && (
      <nav class="border-t border-gray-200 mt-12 pt-6">
        <div class="flex justify-between items-center text-sm">
          <!-- Previous Post -->
          <div class="flex-1">
            {previousPost ? (
              <a href={`/articles/${previousPost.slug}/`} class="inline-flex items-center text-secondary hover:text-accent transition-colors group">
                <svg class="w-4 h-4 mr-2 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                </svg>
                <span class="truncate max-w-[200px]">{previousPost.data.title}</span>
              </a>
            ) : (
              <div></div>
            )}
          </div>
          
          <!-- Center - Articles Link -->
          <div class="flex-shrink-0 mx-4">
            <a href="/articles/" class="text-secondary hover:text-accent transition-colors font-medium">
              All Articles
            </a>
          </div>
          
          <!-- Next Post -->
          <div class="flex-1 text-right">
            {nextPost ? (
              <a href={`/articles/${nextPost.slug}/`} class="inline-flex items-center text-secondary hover:text-accent transition-colors group">
                <span class="truncate max-w-[200px]">{nextPost.data.title}</span>
                <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </a>
            ) : (
              <div></div>
            )}
          </div>
        </div>
      </nav>
    )}
  </article>
</Base>
