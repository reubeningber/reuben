---
import Base from "../layouts/BaseLayout.astro";
---
<Base
  title="Uses | Reuben Ingber"
  description="The tools, gear, and software Reuben Ingber uses."
>
  <div class="max-w-3xl">
    <h1 class="text-4xl font-bold mb-4 text-primary tracking-wide">USES</h1>

    <p class="text-lg leading-relaxed mb-12 text-secondary">
      The tools and gear I actually use, day to day.
    </p>

    <div class="space-y-10">
      <section>
        <h2 class="text-2xl font-bold mb-3 text-primary tracking-wide">TECH</h2>
        <ul class="list-disc list-inside text-lg leading-relaxed space-y-1">
          <li>Apple MacBook Pro (M1, 2021)</li>
          <li>iPhone 16 Pro</li>
          <li>iPad Pro 11"</li>
          <li>Logitech MX Master 3</li>
          <li>Sony WH-CH520</li>
          <li>AirPods Pro</li>
          <li>Western Digital My Passport Ultra 5TB (backups)</li>
          <li>SanDisk Extreme Go Portable SSD 2TB</li>
        </ul>
      </section>

      <section>
        <h2 class="text-2xl font-bold mb-3 text-primary tracking-wide">CAMERA GEAR</h2>
        <ul class="list-disc list-inside text-lg leading-relaxed space-y-1">
          <li>Sony A6700 (main body)</li>
          <li>Nikon L35AF (film)</li>
          <li>Kodak Ultra Max 400</li>
          <li>Sigma 18-50mm F2.8 DC DN | Contemporary</li>
          <li>Sigma 56mm F1.4 DC DN | Contemporary</li>
          <li>Sigma 16mm F1.4 DC DN | Contemporary</li>
          <li>Tamron 70-300mm F/4.5-6.3 Di III RXD</li>
          <li>Lexar UHS-II SD card</li>
          <li>Mastin Labs presets</li>
          <li>Manfrotto Element MII Monopod</li>
          <li>SmallRig camera tripod</li>
          <li>Bellroy Venture Camera Sling</li>
        </ul>
      </section>

      <section>
        <h2 class="text-2xl font-bold mb-3 text-primary tracking-wide">RUNNING GEAR</h2>
        <p class="text-lg leading-relaxed text-secondary italic">
          Coming soon.
        </p>
      </section>
    </div>

    <div class="mt-16 pt-6 border-t border-gray-200 text-sm text-secondary">
      <p>Last updated on July 13, 2026</p>
    </div>
  </div>
</Base>
