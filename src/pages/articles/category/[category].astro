---
import Base from "../../../layouts/BaseLayout.astro";
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  const categoriesSet = new Set<string>();
  
  allPosts.forEach(p => {
    if (!p.data.draft && p.data.category) {
      categoriesSet.add(p.data.category);
    }
  });
  
  const categories = Array.from(categoriesSet);
  
  return categories.map(cat => ({
    params: { category: cat.toLowerCase().replace(/\s+/g, '-') },
    props: { category: cat }
  }));
}

const { category } = Astro.props as { category: string };
const allPosts = await getCollection('posts');
const categoryPosts = allPosts
  .filter(p => !p.data.draft && p.data.category?.toLowerCase() === category.toLowerCase())
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

// Function to create excerpt from post body
function createExcerpt(body, maxLength = 120) {
  const plainText = body
    .replace(/^---[\s\S]*?---/g, '')
    .replace(/#+\s/g, '')
    .replace(/\*\*(.*?)\*\*/g, '$1')
    .replace(/\*(.*?)\*/g, '$1')
    .replace(/\[(.*?)\]\(.*?\)/g, '$1')
    .replace(/`(.*?)`/g, '$1')
    .replace(/\n+/g, ' ')
    .trim();
  
  if (plainText.length <= maxLength) {
    return plainText;
  }
  
  const truncated = plainText.substring(0, maxLength);
  const lastSpace = truncated.lastIndexOf(' ');
  
  return lastSpace > 0 ? truncated.substring(0, lastSpace) + '...' : truncated + '...';
}
---
<Base title={`${category} · Reuben Ingber`} description={`Articles about ${category}`}>
  <div class="mb-12">
    <h1 class="text-4xl font-bold text-primary tracking-wide mb-2">
      {category.toUpperCase()}
    </h1>
    <p class="text-secondary">
      {categoryPosts.length} {categoryPosts.length === 1 ? 'article' : 'articles'}
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
    {categoryPosts.map(p => (
      <article class="bg-white border border-gray-200 rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow">
        {p.data.image && (
          <a href={`/articles/${p.slug}/`} class="block">
            <img 
              src={p.data.image} 
              alt={p.data.title}
              class="w-full h-48 object-cover"
            />
          </a>
        )}
        <div class="p-6">
          <div class="text-sm font-semibold tracking-wide">
            <time datetime={p.data.pubDate.toISOString()} class="text-secondary">
              {p.data.pubDate.toLocaleDateString('en-US', { 
                year: 'numeric', 
                month: 'short', 
                day: 'numeric' 
              }).toUpperCase()}
            </time>
            {p.data.category && (
              <>
                <span class="text-secondary mx-2">|</span>
                <span class="text-accent">
                  {p.data.category.toUpperCase()}
                </span>
              </>
            )}
          </div>
          <h3 class="text-xl font-bold mt-2 mb-3 text-primary tracking-wide">
            <a href={`/articles/${p.slug}/`} class="hover:text-accent no-underline">
              {p.data.title.toUpperCase()}
            </a>
          </h3>
          <p class="text-gray-700 mb-4 leading-relaxed">{createExcerpt(p.body)}</p>
          <a href={`/articles/${p.slug}/`} class="text-accent hover:underline font-semibold text-sm">
            READ MORE >
          </a>
        </div>
      </article>
    ))}
  </div>

  <div class="mt-12 pt-8 border-t border-gray-200">
    <a href="/articles/" class="text-accent hover:underline font-semibold">
      ← ALL ARTICLES
    </a>
  </div>
</Base>
