---
import Base from "../../../layouts/BaseLayout.astro";
import { getCollection } from 'astro:content';
import { getImageConfig } from '../../../utils/cloudinary';
import { isPublished } from '../../../utils/publish';
import { createExcerpt, slugifyCategory } from '../../../utils/content';

const cloudName = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME;

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  const categoriesSet = new Set<string>();

  allPosts.forEach(p => {
    if (!p.data.category) return;
    if (isPublished(p.data.pubDate, p.data.draft)) {
      categoriesSet.add(p.data.category);
    }
  });

  const categories = Array.from(categoriesSet);

  return categories.map(cat => ({
    params: { category: slugifyCategory(cat) },
    props: { category: cat }
  }));
}

const { category } = Astro.props as { category: string };
const allPosts = await getCollection('posts');
const categoryPosts = allPosts
  .filter(p => {
    if (p.data.category?.toLowerCase() !== category.toLowerCase()) return false;
    return isPublished(p.data.pubDate, p.data.draft);
  })
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

function getCategoryImageConfig(imageUrl: string | null | undefined) {
  return getImageConfig(imageUrl, cloudName, [200, 300, 400]);
}
---
<Base title={`${category} · Reuben Ingber`} description={`Articles about ${category} by Reuben Ingber.`}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "@id": `https://reubeningber.com/articles/category/${Astro.params.category}/#webpage`,
    "url": `https://reubeningber.com/articles/category/${Astro.params.category}/`,
    "name": `${category} Articles`,
    "isPartOf": { "@id": "https://reubeningber.com/#website" },
    "author": { "@id": "https://reubeningber.com/#person" },
    "inLanguage": "en-US"
  })}></script>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://reubeningber.com/" },
      { "@type": "ListItem", "position": 2, "name": "Articles", "item": "https://reubeningber.com/articles/" },
      { "@type": "ListItem", "position": 3, "name": category, "item": `https://reubeningber.com/articles/category/${Astro.params.category}/` }
    ]
  })}></script>
  <div class="mb-12">
    <h1 class="text-4xl font-bold text-primary tracking-wide mb-2">
      {category.toUpperCase()}
    </h1>
    <p class="text-secondary">
      {categoryPosts.length} {categoryPosts.length === 1 ? 'article' : 'articles'}
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
    {categoryPosts.map((p, index) => {
      const imageConfig = getCategoryImageConfig(p.data.image);
      const uniqueId = `category-${index}`;
      
      return (
        <article class="bg-white border border-gray-200 rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow">
          {imageConfig && (
            <a href={`/articles/${p.slug}/`} class="block relative">
              {/* Cloudinary images with blur-up effect */}
              {imageConfig.type !== 'external' && (
                <>
                  <!-- Blur-up placeholder -->
                  <img 
                    src={imageConfig.blurUrl}
                    alt={p.data.title}
                    class="w-full h-48 object-cover absolute inset-0 transition-opacity duration-300"
                    id={`blur-${uniqueId}`}
                  />
                  
                  <!-- Main optimized image -->
                  <img 
                    src={imageConfig.mainUrl}
                    srcset={imageConfig.srcset}
                    sizes="(max-width: 768px) 100vw, 50vw"
                    alt={p.data.title}
                    class="w-full h-48 object-cover relative z-10 opacity-0 transition-opacity duration-300"
                    loading="lazy"
                    onload={`this.style.opacity='1'; document.getElementById('blur-${uniqueId}').style.opacity='0';`}
                  />
                </>
              )}
              
              {/* External images - simple lazy loading */}
              {imageConfig.type === 'external' && (
                <img 
                  src={imageConfig.mainUrl}
                  alt={p.data.title}
                  class="w-full h-48 object-cover"
                  loading="lazy"
                />
              )}
            </a>
          )}
          <div class="p-6">
          <div class="text-sm font-semibold tracking-wide">
            <time datetime={p.data.pubDate.toISOString()} class="text-secondary">
              {(() => {
                // Parse date as intended (YYYY-MM-DD) without timezone conversion
                const dateStr = p.data.pubDate instanceof Date 
                  ? p.data.pubDate.toISOString().split('T')[0]
                  : typeof p.data.pubDate === 'string' ? p.data.pubDate : new Date(p.data.pubDate).toISOString().split('T')[0];
                const [year, month, day] = dateStr.split('-');
                const date = new Date(parseInt(year), parseInt(month) - 1, parseInt(day));
                return date.toLocaleDateString('en-US', { 
                  year: 'numeric', 
                  month: 'short', 
                  day: 'numeric' 
                }).toUpperCase();
              })()}
            </time>
            {p.data.category && (
              <>
                <span class="text-secondary mx-2">|</span>
                <span class="text-accent">
                  {p.data.category.toUpperCase()}
                </span>
              </>
            )}
          </div>
            <h3 class="text-xl font-bold mt-2 mb-3 text-primary tracking-wide">
              <a href={`/articles/${p.slug}/`} class="hover:text-accent no-underline">
                {p.data.title.toUpperCase()}
              </a>
            </h3>
            <p class="text-gray-700 mb-4 leading-relaxed">{createExcerpt(p.body)}</p>
            <a href={`/articles/${p.slug}/`} class="inline-flex items-center gap-1 text-accent hover:underline font-semibold text-sm">
              READ MORE
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M13.172 12l-4.95-4.95 1.414-1.414L16 12l-6.364 6.364-1.414-1.414z"/></svg>
            </a>
          </div>
        </article>
      );
    })}
  </div>

  <div class="mt-12 pt-8 border-t border-gray-200">
    <a href="/articles/" class="text-accent hover:underline font-semibold">
      ← ALL ARTICLES
    </a>
  </div>
</Base>
