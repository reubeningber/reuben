---
import Base from "../../layouts/BaseLayout.astro";
import PostList from "../../components/PostList.astro";
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts');
const now = new Date();
const today = now.getFullYear() + '-' +
  String(now.getMonth() + 1).padStart(2, '0') + '-' +
  String(now.getDate()).padStart(2, '0');

const publishedPosts = allPosts.filter(p => {
  if (p.data.draft) return false;
  const pd = p.data.pubDate instanceof Date ? p.data.pubDate : new Date(p.data.pubDate);
  const dateStr = pd.toISOString().split('T')[0];
  return dateStr <= today;
});

const categories = [...new Set(
  publishedPosts
    .map(p => p.data.category)
    .filter(Boolean)
)].sort() as string[];
---
<Base
  title="Articles by Reuben Ingber: Fatherhood, Engineering, Running, Life"
  description="Read Reuben Ingber's articles on parenting, engineering management, running, books, and life lessons. Personal stories and insights from Queens, NY."
>
  <!-- Articles Collection Structured Data -->
  <script type="application/ld+json" slot="head">
    {
      "@context": "https://schema.org",
      "@type": "Blog",
      "@id": "https://reubeningber.com/articles/#blog",
      "url": "https://reubeningber.com/articles/",
      "name": "Reuben Ingber's Articles",
      "description": "Personal blog covering fatherhood, engineering management, running, and life in Queens, NY",
      "author": { "@id": "https://reubeningber.com/#person" },
      "publisher": { "@id": "https://reubeningber.com/#person" },
      "inLanguage": "en-US"
    }
  </script>
  <!-- Category filter chips -->
  <nav aria-label="Filter by category" class="mb-8 flex flex-wrap gap-2">
    <a href="/articles/" class="px-3 py-1 rounded-full text-sm font-semibold bg-accent text-white no-underline">
      All
    </a>
    {categories.map(cat => (
      <a
        href={`/articles/category/${cat.toLowerCase().replace(/\s+/g, '-')}/`}
        class="px-3 py-1 rounded-full text-sm font-semibold border border-gray-300 text-secondary hover:border-accent hover:text-accent transition-colors no-underline"
      >
        {cat}
      </a>
    ))}
  </nav>
  <PostList />
</Base>
