---
import { getCollection } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import { isPublished } from '../../utils/publish';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props;

// Runtime check for development - redirect future posts
if (import.meta.env.DEV) {
  const showDrafts = import.meta.env.SHOW_DRAFTS === 'true';
  const isFuture = !isPublished(post.data.pubDate, false);
  if ((!showDrafts && post.data.draft) || isFuture) {
    return Astro.redirect('/articles/');
  }
}

const { Content } = await post.render();
---
<PostLayout frontmatter={post.data} currentPost={post}>
  <Content />
</PostLayout>
