---
import Base from "../layouts/BaseLayout.astro";
---
<Base
  title="Friends | Reuben Ingber"
  description="People I know and recommend."
>
  <div class="max-w-3xl">
    <h1 class="text-4xl font-bold mb-4 text-primary tracking-wide">FRIENDS</h1>

    <p class="text-lg leading-relaxed mb-8 text-secondary">
      These are some of my internet friends.
    </p>

    <p class="text-lg leading-relaxed">
      <a href="https://nickgray.net" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline font-semibold">Nick Gray</a>
    </p>

    <div class="mt-16 pt-6 border-t border-gray-200 text-sm text-secondary">
      <p>Last updated on July 13, 2026</p>
      <p>Inspired by <a href="https://slashfriends.org" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">slashfriends.org</a></p>
    </div>
  </div>
</Base>
