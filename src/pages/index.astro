---
import Base from "../layouts/BaseLayout.astro";
import PostList from "../components/PostList.astro";
---
<Base 
  title="Reuben Ingber: Personal Home Page, Articles, Photos" 
  description="Father of two in Queens, NY. Engineering Manager at Business Insider. Runner, photographer, and writer sharing thoughts on parenting, engineering, and life."
>
  <section class="mb-16">
    <div class="mb-8">
      <img 
        src="/assets/images/reuben_ingber_october_2025.jpg" 
        alt="Reuben Ingber" 
        class="w-full h-auto rounded-lg object-cover shadow-sm"
      />
    </div>
    
    <div class="prose-lg text-xl max-w-none">
      <p class="text-gray-800 leading-relaxed mb-4">
        Father of two and Queens native, I am a runner, a taker of <a href="/photos/">photos</a> and an Engineering Manager at Business Insider. 
      </p>

      <p class="text-gray-800 leading-relaxed mb-4">
        I truly believe my most important job is waking up my kids every morning and making sure they have a great day. Professioanlly, I am building
        a team and tools to help journalists tell important stories.
      </p>
      
      <p class="text-gray-800 leading-relaxed mb-4">
        I love playing with my kids, taking photos of them, and running through 
        NYC. I have a beautiful wife who I plan to be dating for the rest of my life.
      </p>
      
      <p class="text-gray-800 leading-relaxed">
        I try to make each day unique, set ambitious goals, and relish the journey 
        as much as the endgame.
      </p>

      <p class="text-gray-800 leading-relaxed mb-4">
        Here you'll find my thoughts on parenting, engineer, the occasional race report, and other musings.
      </p>
      
    </div>
    
    <div class="mt-6">
      <a href="/start-here/" class="inline-block border-2 border-accent text-accent text-xl font-semibold px-6 py-3 hover:bg-accent hover:text-white transition-colors duration-200 no-underline tracking-wide">
        READ MORE FUN FACTS ABOUT ME HERE.
      </a>
    </div>
    
    <p class="mt-4 text-xl text-gray-600">Or, here are my most recent articles below.</p>
  </section>

  <section>
    <div class="mb-8">
      <h2 class="text-3xl font-bold mb-4 text-primary tracking-wide">RECENT ARTICLES</h2>
      <hr class="border-gray-200" />
    </div>
    <PostList limit={4} />
    <div class="mt-8 pt-6 text-center">
      <a href="/articles/" class="text-accent hover:underline font-semibold">VIEW ALL ARTICLES ></a>
    </div>
  </section>
</Base>
