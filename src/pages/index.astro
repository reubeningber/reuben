---
import Base from "../layouts/BaseLayout.astro";
import PostList from "../components/PostList.astro";

const cloudName = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME;
---

<Base 
  title="Reuben Ingber: Personal Home Page, Articles, Photos" 
  description="Father of two in Queens, New York. Engineering Manager at Business Insider. Runner, photographer, and writer sharing thoughts on parenting, engineering, and life."
  isHomepage={true}
>
  <!-- Homepage Structured Data -->
  <script type="application/ld+json" slot="head">
    [
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "@id": "https://reubeningber.com/#website",
        "url": "https://reubeningber.com/",
        "name": "Reuben Ingber",
        "publisher": { "@id": "https://reubeningber.com/#person" },
        "inLanguage": "en-US"
      },
      {
        "@context": "https://schema.org",
        "@type": "WebPage",
        "@id": "https://reubeningber.com/#webpage",
        "url": "https://reubeningber.com/",
        "name": "Reuben Ingber — Engineering Manager, Runner, Photographer",
        "isPartOf": { "@id": "https://reubeningber.com/#website" },
        "about": { "@id": "https://reubeningber.com/#person" },
        "inLanguage": "en-US",
        "primaryImageOfPage": {
          "@type": "ImageObject",
          "url": "https://res.cloudinary.com/dt3vcpkj6/image/upload/f_auto,w_1600,h_900,c_fill,g_auto/v1761245976/web_assets/reuben_ingber_october_2025.jpg",
          "width": 1600,
          "height": 900
        }
      }
    ]
  </script>
  <section class="mb-16">
    <div class="mb-8 relative">
      <!-- Blur-up placeholder -->
      <img 
        src={`https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_20,e_blur:2000/v1761245976/web_assets/reuben_ingber_october_2025.jpg`}
        alt="Reuben Ingber"
        class="w-full h-auto rounded-lg object-cover shadow-sm absolute inset-0 transition-opacity duration-300"
        id="hero-placeholder"
        width="1600"
        height="1067"
      />
      
      <!-- Main responsive image -->
      <img 
        src={`https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_1600/v1761245976/web_assets/reuben_ingber_october_2025.jpg`}
        srcset={`
          https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_768/v1761245976/web_assets/reuben_ingber_october_2025.jpg 768w,
          https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_1200/v1761245976/web_assets/reuben_ingber_october_2025.jpg 1200w,
          https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_1600/v1761245976/web_assets/reuben_ingber_october_2025.jpg 1600w
        `}
        sizes="(max-width: 768px) 100vw, (max-width: 1200px) 90vw, 1600px"
        alt="Reuben Ingber" 
        class="w-full h-auto rounded-lg object-cover shadow-sm relative z-10 opacity-0 transition-opacity duration-300"
        width="1600"
        height="1067"
        fetchpriority="high"
        onload="this.style.opacity='1'; document.getElementById('hero-placeholder').style.opacity='0';"
      />
    </div>
    
    <div class="prose-lg text-xl max-w-none">
      <p class="text-gray-800 leading-relaxed mb-4">
        Father of two and Queens native, I am a runner, a taker of <a href="/photos/">photos</a> and an Engineering Manager at <a href="/start-here/" class="text-accent hover:underline">Business Insider</a>. 
      </p>

      <p class="text-gray-800 leading-relaxed mb-4">
        I truly believe my most important job is waking up my kids every morning and making sure they have a great day. Professionally, I am building
        a team and tools to help journalists tell important stories.
      </p>
      
      <p class="text-gray-800 leading-relaxed mb-4">
        I love playing with my kids, taking photos of them, and running through 
        NYC. I am married to a beautiful woman who I plan to be dating everyday for the rest of my life.
      </p>
      
      <p class="text-gray-800 leading-relaxed mb-4">
        I try to make each day unique, set ambitious goals, and love the journey.
      </p>

      <p class="text-gray-800 leading-relaxed mb-4">
        Here you'll find my <a href="/articles/" class="text-accent hover:underline">thoughts</a> on <a href="/articles/category/fatherhood/" class="text-accent hover:underline">parenting</a>, <a href="/articles/category/engineering/" class="text-accent hover:underline">engineering</a>, the occasional race report, and other musings. You can also check out some of my latest <a href="/photos/" class="text-accent hover:underline">photography</a>.
      </p>

      <p class="text-gray-800 leading-relaxed mb-4">
        I love meeting interesting people and hearing their stories. Whether you're a fellow parent, engineer, runner, photographer, or just someone doing meaningful work, I'd love to <a href="/contact/" class="text-accent hover:underline">connect</a>.
      </p>
      
    </div>
    
    <div class="mt-6">
      <a href="/start-here/" class="inline-block border-2 border-accent text-accent text-xl font-semibold px-6 py-3 hover:bg-accent hover:text-white transition-colors duration-200 no-underline tracking-wide">
        READ MORE FUN FACTS ABOUT ME HERE.
      </a>
    </div>
    
    <p class="mt-4 text-xl text-gray-600">Or, here are my most recent articles below.</p>
  </section>

  <section>
    <div class="mb-8">
      <h2 class="text-3xl font-bold mb-4 text-primary tracking-wide">RECENT ARTICLES</h2>
      <hr class="border-gray-200" />
    </div>
    <PostList limit={4} />
    <div class="mt-8 pt-6 text-center">
      <a href="/articles/" class="text-accent hover:underline font-semibold">VIEW ALL ARTICLES ></a>
    </div>
  </section>
</Base>
