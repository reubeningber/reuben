---
import Base from "../layouts/BaseLayout.astro";
import PostList from "../components/PostList.astro";
---
<Base>
  <section class="mb-12">
    <div class="rounded-2xl p-6 sm:p-8 border border-gray-200">
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight mb-3">Hi, I'm Reuben.</h1>
      <p class="text-lg leading-relaxed max-w-prose">
        Father of two in Queens, runner, Engineering Manager at Business Insider. I love playing with my kids and taking photos of them.
      </p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href="/about/" class="inline-flex items-center gap-2 rounded-2xl px-4 py-2 border border-accent no-underline hover:bg-accent/10">About</a>
        <a href="/blog/" class="inline-flex items-center gap-2 rounded-2xl px-4 py-2 border border-gray-300 no-underline hover:bg-gray-50">Blog</a>
        <a href="/photos/" class="inline-flex items-center gap-2 rounded-2xl px-4 py-2 border border-gray-300 no-underline hover:bg-gray-50">Photos</a>
      </div>
    </div>
  </section>

  <section class="mb-12">
    <h2 class="text-xl font-semibold mb-4">Latest posts</h2>
    <PostList />
  </section>

  <section>
    <h2 class="text-xl font-semibold mb-4">Featured photos</h2>
    <p>Check out the <a href="/photos/">photos section</a> for a sample album.</p>
  </section>
</Base>
