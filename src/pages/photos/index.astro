---
import Base from "../../layouts/BaseLayout.astro";
import PhotoGridWithLightbox from "../../components/PhotoGridWithLightbox.astro";
import { getCollection } from 'astro:content';

const cloudName = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME;

const albums = await getCollection('albums');

// Get the featured albums
const featuredFamily = albums.find(album => album.data.slug === 'featured-family');
const featuredPhotos = albums.find(album => album.data.slug === 'featured-photos');
---
<Base 
  title="Photos by Reuben Ingber: Family, NYC, Life in Queens" 
  description="Browse photos by Reuben Ingber. Family moments, NYC scenes, and life in Queens captured with a Sony A6000. Street photography and personal memories."
>
  <!-- Photos Collection Structured Data -->
  <script type="application/ld+json" slot="head">
    {
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      "@id": "https://reubeningber.com/photos/#collection",
      "url": "https://reubeningber.com/photos/",
      "name": "Reuben Ingber Photography",
      "isPartOf": { "@id": "https://reubeningber.com/#website" },
      "about": { "@id": "https://reubeningber.com/#person" },
      "inLanguage": "en-US",
      "description": "A collection of photographs taken by Reuben Ingber — runner, father, and photographer based in Queens, NY."
    }
  </script>
  
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-4xl font-bold text-primary tracking-wide">PHOTOS</h1>
    <a href="/photos/albums/" class="text-accent hover:underline font-semibold text-sm">VIEW ALBUMS &gt;</a>
  </div>

  <!-- Tab Navigation -->
  <div class="border-b border-gray-200 mb-6">
    <nav class="flex space-x-8">
      <button 
        class="tab-button py-2 px-1 border-b-2 font-medium text-sm transition-colors active"
        data-tab="family"
      >
        FAMILY
      </button>
      <button 
        class="tab-button py-2 px-1 border-b-2 font-medium text-sm transition-colors"
        data-tab="highlights"
      >
        HIGHLIGHTS
      </button>
    </nav>
  </div>

  <!-- Tab Content -->
  <div class="tab-content" id="family-tab">
    {featuredFamily && (
      <PhotoGridWithLightbox items={featuredFamily.data.items} galleryId="family-gallery" />
    )}
  </div>

  <div class="tab-content hidden" id="highlights-tab">
    {featuredPhotos && (
      <PhotoGridWithLightbox items={featuredPhotos.data.items} galleryId="highlights-gallery" />
    )}
  </div>

  <script>
    import PhotoSwipeLightbox from 'photoswipe/lightbox';
    import 'photoswipe/style.css';
    
    // Tab functionality
    const tabButtons = document.querySelectorAll('.tab-button');
    const tabContents = document.querySelectorAll('.tab-content');
    
    // Initialize lightboxes for both galleries
    const familyLightbox = new PhotoSwipeLightbox({
      gallery: '#family-gallery',
      children: 'a',
      showHideAnimationType: 'fade',
      pswpModule: () => import('photoswipe')
    });
    
    const highlightsLightbox = new PhotoSwipeLightbox({
      gallery: '#highlights-gallery',
      children: 'a',
      showHideAnimationType: 'fade',
      pswpModule: () => import('photoswipe')
    });
    
    // Add dynamic dimensions for both lightboxes
    [familyLightbox, highlightsLightbox].forEach(lightbox => {
      lightbox.addFilter('itemData', (itemData, index) => {
        const img = itemData.element.querySelector('img');
        if (img) {
          const aspectRatio = img.naturalWidth / img.naturalHeight;
          itemData.width = 2400;
          itemData.height = Math.round(2400 / aspectRatio);
        }
        return itemData;
      });
    });
    
    familyLightbox.init();
    highlightsLightbox.init();
    
    // Tab switching functionality
    tabButtons.forEach(button => {
      button.addEventListener('click', () => {
        const targetTab = button.getAttribute('data-tab');
        
        // Update button states
        tabButtons.forEach(btn => {
          btn.classList.remove('active');
          btn.classList.add('text-gray-500', 'border-transparent');
          btn.classList.remove('text-accent', 'border-accent');
        });
        
        button.classList.add('active');
        button.classList.remove('text-gray-500', 'border-transparent');
        button.classList.add('text-accent', 'border-accent');
        
        // Update content visibility
        tabContents.forEach(content => {
          content.classList.add('hidden');
        });
        
        document.getElementById(`${targetTab}-tab`).classList.remove('hidden');
      });
    });
    
    // Initialize default tab state
    document.addEventListener('DOMContentLoaded', () => {
      const activeButton = document.querySelector('.tab-button.active');
      if (activeButton) {
        activeButton.classList.add('text-accent', 'border-accent');
        activeButton.classList.remove('text-gray-500', 'border-transparent');
      }
      
      // Set inactive buttons
      tabButtons.forEach(btn => {
        if (!btn.classList.contains('active')) {
          btn.classList.add('text-gray-500', 'border-transparent');
        }
      });
    });
  </script>

  <style>
    .tab-button {
      @apply text-gray-500 border-transparent hover:text-gray-700 hover:border-gray-300;
    }
    
    .tab-button.active {
      @apply text-accent border-accent;
    }
  </style>
</Base>
