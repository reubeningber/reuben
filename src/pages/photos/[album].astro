---
import Base from "../../layouts/BaseLayout.astro";
import { getCollection } from 'astro:content';

// Build Cloudinary URL with responsive width
function buildUrl(publicId, width = 1200) {
  const cloud = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME;
  return `https://res.cloudinary.com/${cloud}/image/upload/f_auto,w_${width}/${publicId}.jpg`;
}

export async function getStaticPaths() {
  const albums = await getCollection('albums');
  return albums.map((a) => ({ params: { album: a.data.slug }, props: { album: a } }));
}

const { album } = Astro.props;
const cloudName = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME;

// Shuffle array randomly using Fisher-Yates algorithm
function shuffleArray(array) {
  const shuffled = [...array];
  for (let i = shuffled.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
  }
  return shuffled;
}

// Randomize photo order
const randomizedItems = shuffleArray(album.data.items);

// Generate og:image from album cover
const coverPublicId = album.data.coverPublicId || album.data.items[0].publicId;
const ogImage = `https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_1200,h_630,c_fill/${coverPublicId}.jpg`;
---
<Base title={`${album.data.title} · Photos · Reuben Ingber`} ogImage={ogImage}>
  <h1 class="text-2xl font-bold mb-4">{album.data.title}</h1>
  {album.data.description && <p class="mb-6 text-gray-700">{album.data.description}</p>}

  <div class="columns-2 sm:columns-3 gap-3" id="gallery">
    {randomizedItems.map((it, idx) => (
      <a href={buildUrl(it.publicId, 2400)} class="block mb-3 break-inside-avoid" data-pswp-src={buildUrl(it.publicId, 2400)}>
        <img src={buildUrl(it.publicId, 600)} alt={it.caption || ''} loading="lazy" class="w-full h-auto rounded-lg hover:opacity-90 transition-opacity" />
      </a>
    ))}
  </div>

  <script>
    import PhotoSwipeLightbox from 'photoswipe/lightbox';
    import 'photoswipe/style.css';
    
    const lightbox = new PhotoSwipeLightbox({
      gallery: '#gallery',
      children: 'a',
      showHideAnimationType: 'fade',
      pswpModule: () => import('photoswipe')
    });
    
    // Dynamically get image dimensions from the thumbnail
    lightbox.addFilter('itemData', (itemData, index) => {
      const img = itemData.element.querySelector('img');
      if (img) {
        // Use natural dimensions or calculate from thumbnail
        const aspectRatio = img.naturalWidth / img.naturalHeight;
        itemData.width = 2400;
        itemData.height = Math.round(2400 / aspectRatio);
      }
      return itemData;
    });
    
    lightbox.init();
  </script>
</Base>
