---
// Import the same content as the main photos page but with highlights tab active
import PhotoLayout from "../../layouts/PhotoLayout.astro";
import PhotoGridWithLightbox from "../../components/PhotoGridWithLightbox.astro";
import { getCollection } from 'astro:content';

const cloudName = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME;
const albums = await getCollection('albums');

// Get the featured albums
const featuredFamily = albums.find(album => album.data.slug === 'featured-family');
const featuredPhotos = albums.find(album => album.data.slug === 'featured-photos');

// Get regular albums (excluding featured ones)
const regularAlbums = albums
  .filter(album => !album.data.slug.startsWith('featured-'))
  .sort((a, b) => 
    new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
  );

// Get album cover image configuration
function getAlbumCoverConfig(album) {
  const publicId = album.data.coverPublicId || album.data.items[0].publicId;
  
  return {
    blurUrl: `https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_20,e_blur:2000/${publicId}.jpg`,
    mainUrl: `https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_600/${publicId}.jpg`,
    srcset: `
      https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_300/${publicId}.jpg 300w,
      https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_450/${publicId}.jpg 450w,
      https://res.cloudinary.com/${cloudName}/image/upload/f_auto,w_600/${publicId}.jpg 600w
    `
  };
}

const activeTab = 'highlights';
---

<PhotoLayout 
  title="Photo Highlights by Reuben Ingber" 
  description="Browse photo highlights by Reuben Ingber. My favorite recent photos from Queens, NY and beyond."
>
  <!-- Photos Collection Structured Data -->
  <script type="application/ld+json" slot="head">
    {
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      "@id": "https://reubeningber.com/photos/highlights/#collection",
      "url": "https://reubeningber.com/photos/highlights/",
      "name": "Reuben Ingber Photo Highlights",
      "isPartOf": { "@id": "https://reubeningber.com/#website" },
      "about": { "@id": "https://reubeningber.com/#person" },
      "inLanguage": "en-US",
      "description": "A collection of highlight photographs taken by Reuben Ingber — runner, father, and photographer based in Queens, NY."
    }
  </script>
  
  <h1 class="text-4xl font-bold mb-6 text-primary tracking-wide">PHOTOS</h1>

  <!-- Tab Navigation -->
  <div class="border-b border-gray-200 mb-6">
    <nav class="flex space-x-8">
      <a 
        href="/photos/"
        class={`tab-link py-2 px-1 border-b-2 font-medium text-sm transition-colors ${activeTab === 'family' ? 'active' : ''}`}
      >
        FAMILY
      </a>
      <a 
        href="/photos/highlights/"
        class={`tab-link py-2 px-1 border-b-2 font-medium text-sm transition-colors ${activeTab === 'highlights' ? 'active' : ''}`}
      >
        HIGHLIGHTS
      </a>
      <a 
        href="/photos/albums/"
        class={`tab-link py-2 px-1 border-b-2 font-medium text-sm transition-colors ${activeTab === 'albums' ? 'active' : ''}`}
      >
        ALBUMS
      </a>
    </nav>
  </div>

  <!-- Tab Content -->
  <div class={`tab-content ${activeTab !== 'family' ? 'hidden' : ''}`} id="family-tab">
    {featuredFamily && (
      <PhotoGridWithLightbox items={featuredFamily.data.items} galleryId="family-gallery" />
    )}
  </div>

  <div class={`tab-content ${activeTab !== 'highlights' ? 'hidden' : ''}`} id="highlights-tab">
    {featuredPhotos && (
      <PhotoGridWithLightbox items={featuredPhotos.data.items} galleryId="highlights-gallery" />
    )}
  </div>

  <div class={`tab-content ${activeTab !== 'albums' ? 'hidden' : ''}`} id="albums-tab">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      {regularAlbums.map((album, index) => {
        const coverConfig = getAlbumCoverConfig(album);
        const uniqueId = `album-cover-${index}`;
        
        return (
          <div class="border border-gray-200 rounded-xl overflow-hidden hover:shadow-md transition-shadow">
            <a class="block no-underline" href={`/photos/${album.data.slug}/`}>
              <div class="relative">
                <!-- Blur-up placeholder -->
                <img
                  src={coverConfig.blurUrl}
                  alt={album.data.title}
                  class="w-full h-auto absolute inset-0 transition-opacity duration-300"
                  id={`blur-${uniqueId}`}
                />
                
                <!-- Main optimized cover image -->
                <img
                  src={coverConfig.mainUrl}
                  srcset={coverConfig.srcset}
                  sizes="(max-width: 640px) 100vw, 50vw"
                  alt={album.data.title}
                  class="w-full h-auto relative z-10 opacity-0 transition-opacity duration-300"
                  loading="lazy"
                  onload={`this.style.opacity='1'; document.getElementById('blur-${uniqueId}').style.opacity='0';`}
                />
              </div>
              
              <div class="p-4">
                <h3 class="font-semibold">{album.data.title}</h3>
                {album.data.description && <p class="text-sm text-gray-600 mt-1">{album.data.description}</p>}
              </div>
            </a>
          </div>
        );
      })}
    </div>
  </div>

  <script>
    import PhotoSwipeLightbox from 'photoswipe/lightbox';
    import 'photoswipe/style.css';
    
    // Initialize lightboxes for photo galleries
    const familyLightbox = new PhotoSwipeLightbox({
      gallery: '#family-gallery',
      children: 'a',
      showHideAnimationType: 'fade',
      pswpModule: () => import('photoswipe')
    });
    
    const highlightsLightbox = new PhotoSwipeLightbox({
      gallery: '#highlights-gallery',
      children: 'a',
      showHideAnimationType: 'fade',
      pswpModule: () => import('photoswipe')
    });
    
    // Add dynamic dimensions for both lightboxes
    [familyLightbox, highlightsLightbox].forEach(lightbox => {
      lightbox.addFilter('itemData', (itemData, index) => {
        const img = itemData.element?.querySelector('img');
        if (img) {
          const aspectRatio = img.naturalWidth / img.naturalHeight;
          itemData.width = 2400;
          itemData.height = Math.round(2400 / aspectRatio);
        }
        return itemData;
      });
    });
    
    familyLightbox.init();
    highlightsLightbox.init();
  </script>

  <style>
    .tab-link {
      @apply text-gray-500 border-transparent hover:text-gray-700 hover:border-gray-300 no-underline;
    }
    
    .tab-link.active {
      @apply text-accent border-accent;
    }
  </style>
</Base>